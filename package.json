{
  "name": "@ogs-gmbh/_ts-template",
  "version": "1.0.0",
  "description": "A project template with a ready-to-use structure.",
  "keywords": [
    "template",
    "starter",
    "project-structure",
    "scalable",
    "reusable",
    "modular",
    "maintainable",
    "clean-code",
    "boilerplate",
    "development-ready",
    "application-foundation"
  ],
  "homepage": "https://ogs-gmbh.github.io/_ts-template/",
  "bugs": "https://github.com/OGS-GmbH/_ts-template/issues",
  "license": "MIT",
  "author": "OGS GmbH",
	"contributors": [
		{
			"name": "Simon Kovtyk",
			"email": "simon@kovtyk.com",
			"url": "https://simonkov.dev"
		}
	],
  "exports": {
    ".": {
      "types": "./public-api.d.ts",
      "default": "./public-api.mjs"
    }
  },
  "repository": "https://github.com/OGS-GmbH/_ts-template",
  "type": "module",
  "scripts": {
    "ci:build:main:production": "node .esbuild/build.mjs",
    "ci:docs:extract:typedoc": "typedoc",
    "ci:docs:main:vitepress": "bash ./.vitepress/scripts/pre-vitepress.sh && vitepress build .vitepress",
    "ci:pr:commitlint:main:commitlint": "commitlint",
    "ci:pr:lint:main:eslint": "eslint .",
    "commit": "commit",
    "prepare": "husky",
    "vitepress": "bash ./.vitepress/scripts/pre-vitepress.sh && vitepress dev .vitepress",
    "vitepress:preview": "vitepress preview .vitepress"
  },
  "devDependencies": {
    "esbuild": "^0.27.2",
    "esbuild-plugin-d.ts": "^1.3.1",
    "esbuild-plugin-file-copy": "2.0.0-next.0",
    "esbuild-plugin-file-path-extensions": "^2.1.4",
    "esbuild-plugin-package-json": "^2.0.0",
    "fast-glob": "^3.3.3",
    "typescript": "^5.9.3",
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@commitlint/prompt-cli": "^20.3.1",
    "@eslint/js": "^9.39.2",
    "@eslint/json": "^0.14.0",
    "@eslint/markdown": "^7.5.1",
    "@ogs-gmbh/linter": "^2",
    "@ogs-gmbh/vitepress-plugin-sidebar": "^1.0.2",
    "@ogs-gmbh/vitepress-theme": "^1.0.1",
    "@stylistic/eslint-plugin": "^5.7.1",
    "eslint": "^9.39.2",
    "eslint-plugin-jsdoc": "^62.4.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-unicorn": "^56.0.1",
    "globals": "^17.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "npm-package-json-lint": "^9.1.0",
    "sass-embedded": "^1.97.3",
    "typedoc": "^0.28.16",
    "typedoc-plugin-frontmatter": "^1.3.1",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript-eslint": "^8.53.1",
    "vitepress": "^1.6.4",
    "vitepress-plugin-group-icons": "^1.7.1"
  },
  "publishConfig": {
    "directory": "dist/main"
  }
}
